# Database configuration
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Database connection string
DATABASE_URL=

# Database direct connection string
DIRECT_URL=

# Emailing — desarrollo local: MailHog captura todos los emails sin enviarlos realmente.
# El .env.template ya viene con los valores correctos para pnpm dev (MailHog en localhost:1025).
# ¿Todavía no tenés MailHog? Un solo comando lo levanta:
#   docker run -d --name mailhog -p 1025:1025 -p 8025:8025 mailhog/mailhog
# Producción: dejá SMTP_HOST vacío → se usa Gmail con SMTP_USER/SMTP_PASS (vienen de los secrets de Kamal).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# AWS
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_CLOUDFRONT_URL=